CLIENT_ID=car-001

# One car can have multiple cameras.
# cam-1/cam-2: Wisenet, cam-3/cam-4: Milesight
MEDIA_SOURCES=[{"id":"cam-1","type":"rtsp","url":"rtsp://admin:admin251-325@192.168.1.100:554/profile2/media.smp","rtsp_options":{"rtsp_transport":"tcp","fflags":"nobuffer","flags":"low_delay","max_delay":"0","reorder_queue_size":"0","analyzeduration":"0","probesize":"500000"}},{"id":"cam-2","type":"rtsp","url":"rtsp://admin:admin251-325@192.168.1.101:554/profile2/media.smp","rtsp_options":{"rtsp_transport":"tcp","fflags":"nobuffer","flags":"low_delay","max_delay":"0","reorder_queue_size":"0","analyzeduration":"0","probesize":"500000"}},{"id":"cam-3","type":"rtsp","url":"rtsp://admin:admin251-325@192.168.5.190:554//main"},{"id":"cam-4","type":"rtsp","url":"rtsp://admin:admin251-325@192.168.5.191:554//main"}]
DEFAULT_CAMERA_ID=cam-1

# Default webcam ffmpeg options for webcam sources
DEFAULT_WEBCAM_OPTIONS={"framerate":"30","video_size":"1280x720"}

# Placeholder frame when camera is unavailable / reconnecting
PLACEHOLDER_IMAGE_PATH=assets/no_signal.png
PLACEHOLDER_FPS=15

# RTSP low-latency ffmpeg options
RTSP_OPTIONS={"rtsp_transport":"tcp","fflags":"nobuffer","flags":"low_delay","max_delay":"500","reorder_queue_size":"50","analyzeduration":"2000000"}

SIGNALING_WS_URL=ws://localhost:4000/ws

# Demo token for insecure signaling mode.
SIGNALING_AUTH_TOKEN=demo

ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]}]
KEYCLOAK_TOKEN_URL=
KEYCLOAK_CLIENT_ID=car-service
KEYCLOAK_CLIENT_SECRET=change-me
TOKEN_REFRESH_MARGIN=30
LOG_LEVEL=INFO
