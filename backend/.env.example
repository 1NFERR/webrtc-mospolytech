SIGNALING_HOST=0.0.0.0
SIGNALING_PORT=8765

# Preferred: set 4 separate camera variables (no JSON needed)
CAMERA_0=rtsp://user:pass@192.168.1.10:554/stream1
CAMERA_1=rtsp://user:pass@192.168.1.11:554/stream1
CAMERA_2=rtsp://user:pass@192.168.1.12:554/stream1
CAMERA_3=rtsp://user:pass@192.168.1.13:554/stream1
#
# Optional alternative (advanced): JSON list of strings
# CAMERA_SOURCES=["rtsp://...","rtsp://...","rtsp://...","rtsp://..."]

CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Try to keep latency low for RTSP:
# - small capture buffer
CAMERA_BUFFERSIZE=1
#
# OpenCV (FFmpeg backend) capture options. Common RTSP example:
# OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp|stimeout;5000000|max_delay;500000
OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp

